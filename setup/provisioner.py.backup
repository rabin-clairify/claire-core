import subprocess
import sys
import json
from pathlib import Path

def create_bot(user_name, port, tg_token, tg_id):
    agent_dir = Path(f"/home/clairify/claires/agents/{user_name}")

    # Check if the folder already exists
    if agent_dir.exists() and agent_dir.is_dir():
        # Feed Openclaire clear instructions on how to handle this situation
        return {
            "status": "exists", 
            "message": f"System Notice: A bot named 'claire-{user_name}' already exists. Inform the user that it already exists and politely ask them to please create the bot with another name."
        }

    script_path = "/home/clairify/claires/setup/spawn_claire.sh"

    try:
        result = subprocess.run(
            ["sudo", script_path, user_name, str(port), tg_token, str(tg_id)],
            capture_output=True, text=True, check=True
        )
        return {"status": "success", "output": result.stdout}
    except subprocess.CalledProcessError as e:
        return {"status": "error", "message": e.stderr}

if __name__ == "__main__":
    args = json.loads(sys.argv[1])
    response = create_bot(args['user_name'], args['port'], args['tg_token'], args['tg_id'])
    print(json.dumps(response))
